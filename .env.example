# Copy this file to .env and fill in real values. .env is gitignored.

# Which LLM provider backs get_llm(role): gemini | groq | anthropic | ollama
PACTUM_LLM_PROVIDER=groq

# Only the key matching PACTUM_LLM_PROVIDER is required.
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
# Ollama needs no key; it must be running locally (ollama serve).

# Contract registry (Postgres, started via docker compose up postgres)
DATABASE_URL=postgresql://pactum:pactum@localhost:5432/pactum
